@{
    ViewData["Title"] = "Edit Lobby";
    string[] Moods = {"Chill","Hardcore","Not Toxic","Toxic","God"};
    string[] Games = { 
    "Elden Ring", 
    "Monster Hunter: World", 
    "Remnant 2", 
    "Dark Souls III", 
    "Helldivers 2", 
    "Baldur's Gate 3", 
    "It Takes Two", 
    "Lords of the Fallen", 
    "Valheim", 
    "Palworld", 
    "Deep Rock Galactic", 
    "Left 4 Dead 2", 
    "Stardew Valley", 
    "Sea of Thieves", 
    "Don't Starve Together", 
    "Grand Theft Auto Online", 
    "Apex Legends", 
    "Warframe", 
    "Destiny 2", 
    "Minecraft" 
    };
}
@using GamerLFG.Services.Interface.DTOs;
@model EditLobbyDTO;
<script src="~/js/create-lobby.js" asp-append-version="true" defer></script>
<link rel="stylesheet" href="~/css/create_lobby.css" asp-append-version="true">
<script>
    // Roles occupied by active members — cannot be removed or renamed
    const occupiedRoles = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.OccupiedRoles));</script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        @{int idx = 0;}
        @if (Model.Roles != null && Model.Roles.Any())
        {
            foreach (var role in Model.Roles)
            {
                <text>
                itemsArray.push({ id: Date.now() + @(idx++), lable: "@Html.Raw(role.Replace("\"","\\\""))", quantity: 1 });
                </text>
            }
        }
        
        @if (Model.Moods != null && Model.Moods.Any())
        {
            foreach (var mood in Model.Moods)
            {
                <text>
                var cb = document.getElementById('mood-' + '@mood');
                if (cb) cb.checked = true;
                </text>
            }
        }
        
        // Mark locked based on occupiedRoles, then render
        itemsArray = itemsArray.map(function(item) {
            item.locked = occupiedRoles.includes(item.lable);
            return item;
        });

        itemsArray.forEach(function(item) {
            var itemDiv = document.createElement("div");
            itemDiv.className = "item-box";
            itemDiv.id = "item-" + item.id;
            itemDiv.innerHTML = buildRoleCard(item);
            document.getElementById("roles-added").appendChild(itemDiv);
        });
        updateHiddenInput();
    });
</script>
<link rel="stylesheet" href="~/css/create_lobby.css" asp-append-version="true">
<main>
    <form asp-controller="Lobby" asp-action="EditMission" class="create-form" method="post">
        <div asp-validation-summary="All" class="text-danger"></div>
        <input type="hidden" asp-for="Id">
        <div class="title">
            <label for="game">Choose Your Game</label>
            <select asp-for="Game" 
                            asp-items="@(new SelectList(Games))" 
                            class="form-control">
                        <option value="">-- เลือกเกม --</option>
                    </select>
            
                    
            <input asp-for="Title" type="text" placeholder="Lobby title">
            <input asp-for="Description" type="text"  placeholder="description">
        </div>
        <div>
                    <input type="number" asp-for="MaxPlayers" id="min" oninput=" this.value = this.value.replace(/[^2-100]/g, '')">
                    <div id="add-count-btn">
                        <button type="button" onclick="countingTime(1,'min')"><i class="fa fa-arrow-up"></i></button>
                        <button type="button" onclick="countingTime(-1,'min')"><i class="fa fa-arrow-down"></i></button>
                    </div>
                    <p>MIN</p>
        </div>

        <div class="require">
            <p id="re-text-1">PERSONAL REQUIREMENTS</p>
            <p id="re-text-2">ASSIGN SPASIFIC ROLES FOR THE SQUAD</p>

            <div class="input-role">
                <input type="text" placeholder="Role Assign" id="key-role">
                <input type="text" id="count" value="1" oninput="this.value = this.value.replace(/[^0-9]/g, '')">
                <div id="add-count-btn">
                    <button type="button" onclick="counting(1,'count')"><i class="fa fa-arrow-up"></i></button>
                    <button type="button" onclick="counting(-1,'count')"><i class="fa fa-arrow-down"></i></button>
                </div>
                 <button onclick="addToDOM()" id="add-role-btn" type="button"><strong>ADD ROLE</strong></i></button>
            </div>
        <div id="roles-added"></div>

        <div id="roles-hidden-container"></div>
        </div>


        <div class="mood-select">
            <p>TACTICAL PROTOCAL TAGS</p>
            <div class=moods>
                @foreach(string mood in Moods){
                <input type="checkbox" name="Moods" id="mood-@mood" value="@mood" class="check-box"> 
                <label class="mood-label" for=@mood>@mood</label>
            }   
            </div>

        </div>
        <div class="wallpaper">
            <p>Tactical Visuals</p>
            <input type="text" placeholder="Direct Image URL" asp-for="Picture">
        </div>
        <div class="discord">
            <p>Discord Link</p>
            <input type="text" placeholder="discord" asp-for="DiscordLink">
            
        </div>
        
        <div class="date">
            <label for="start" class="datetime-local">
                <div class="calendar">
                 Open Recruit Date <i class="fa fa-calendar"></i>   
                </div>
               
               <input type="datetime-local" onclick="this.showPicker()" class="input-date" id="start" asp-for="StartRecruiting"> 
            </label>
             <label for="end" class="datetime-local">
                <div class="calendar">
                  Close Recruit Date <i class="fa fa-calendar"></i>  
                </div>
               
              <input type="datetime-local" onclick="this.showPicker()" class="input-date" id="end" asp-for="EndRecruiting">  

             </label>
            <label for="start-e" class="datetime-local">
                <div class="calendar">
                  Start Event Date <i class="fa fa-calendar"></i>  
                </div>
               
              <input type="datetime-local" onclick="this.showPicker()" class="input-date" id="start-e" asp-for="StartEvent">  
             </label>

             <label for="end-e" class="datetime-local">
                <div class="calendar">
                  End Event Date <i class="fa fa-calendar"></i>  
                </div>
               
              <input type="datetime-local" onclick="this.showPicker()" class="input-date" id="end-e" asp-for="EndEvent">  
             </label>
        </div>

        <button class="orange-button">
            SAVE CHANGES
        </button>
    </form>
</main>
