@model List<GamerLFG.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
}

<link rel="stylesheet" href="~/css/notifications.css" asp-append-version="true" />

<div class="noti-page-container">
    <div class="noti-page-header">
        <h2>Notifications</h2>
    </div>

    <div class="noti-list">
        @if (Model != null && Model.Any())
        {
            @foreach (var item in Model)
            {
                <div class="noti-item @(item.IsRead ? "" : "unread")" 
                    onclick="readNotification(this, '@item.Id', '@item.Type','@item.RelateObjectId')" 
                    id="noti-@item.Id">
                    
                    <div class="noti-text-wrapper">
                        <p class="noti-message">@item.Text</p>
                        <span class="noti-time">@item.Date.ToString("g")</span>
                    </div>

                    @if (!item.IsRead)
                    {
                        <span class="red-dot"></span>
                    }
                </div>
            }
        }
        else
        {
            <div class="noti-empty">
                <p>No notifications</p>
            </div>
        }
    </div>
</div>

<script>
    function readNotification(element, id, type, relateObjectId) {
        // ถ้าอ่านแล้ว ให้กดแล้วพาไปหน้าเป้าหมาย
        if (!element.classList.contains('unread')) {
            redirectBasedOnType(type, relateObjectId);
            return;
        }

        // AJAX อ่านแล้ว
        fetch('/Noti/MarkAsRead', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `id=${id}`
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                
                element.classList.remove('unread');
                const dot = element.querySelector('.red-dot');
                if (dot) dot.remove();

                
                redirectBasedOnType(type,relateObjectId);
            }
        })
        .catch(err => console.error("Error marking as read:", err));
    }

    
    function redirectBasedOnType(type,relateObjectId) {
        if (type === 'friend_request') {
            window.location.href = '/FriendRequest/FriendRequestList';
        }
        else if (type === 'friend_accept'){
             window.location.href = '/User/Friends_list';
        }
        else if (type === "lobby_request_apply" || type ==="lobby_accepted" || type === "lobby_rejected"
            || type === "lobby_invite" || type === "lobby_invite_request" || type === "lobby_invite_approved"
            || type === "lobby_invite_rejected" || type === "lobby_invite_declined"){
            window.location.href = '/Lobby/Details/' + relateObjectId;
        }
    }
</script>