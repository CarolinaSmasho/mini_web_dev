@model GamerLFG.Models.User
@using System.Security.Claims

@{
    ViewData["Title"] = "Profile";

    string Logged_id = User.FindFirstValue(ClaimTypes.NameIdentifier)?.Trim().ToLower();

    string id = Model?.Id?.Trim().ToLower();

    bool isOwnProfile = (Logged_id == id);

    string Name = Model.Name;
    string pic = Model.Avatar;
    string bio = Model.Bio;

    string gameLibraryDisplay = Model.GameLibrary != null ? string.Join(", ", Model.GameLibrary) : "";

    string discord = Model.discord;
    string steam = Model.steam;
    string twitch = Model.twitch;

    double karmaScore = Model.KarmaScore;

    int karmaPercent = Math.Clamp((int)((karmaScore + 100) / 2), 0, 100);

    string tierName = "";
    string tierColor = "";

    if (karmaScore >= 50)
    {
        tierName = "Excellent";
        tierColor = "#00d2ff";
    }
    else if (karmaScore >= 0)
    {
        tierName = "Good";
        tierColor = "#28a745";
    }
    else if (karmaScore > -50)
    {
        tierName = "Warning";
        tierColor = "#ff9800";
    }
    else
    {
        tierName = "Restricted";
        tierColor = "#ff2828";
    }
}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

<link rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />

<link rel="stylesheet" href="~/css/profiles.css" asp-append-version="true" />

<div class="main-content">
    <div class="container">
        <div class="col-left">
            <div class="box" style="text-align: center;">
                @if (isOwnProfile)
                {
                    <div class="profile-img" onclick="changeAvatar()" style="cursor: pointer;">
                        <img id="profileImage" src="@pic" />
                    </div>
                }
                else
                {
                    <div class="profile-img">
                        <img id="profileImage" src="@pic" />
                    </div>
                }

                <h3>@Name</h3>
                <span
                    style="background: @tierColor; color: black; padding: 3px 6px; font-size: 12px; font-weight: bold;">
                    @tierName Member
                </span>
            </div>

            <div class="box">
                <h2>Karma Score</h2>
                <div style="font-size: 36px; font-weight: bold;">@karmaScore</div>
                <div style="color: @tierColor; font-weight: bold;">Status: @tierName</div>

                <div class="bar-bg">
                    <div class="bar-fill" style="width: @(karmaPercent)%;"></div>
                </div>

                <br>
                <a asp-controller="Karma" asp-action="KarmaHistory" asp-route-userId="@Model.Id"
                   style="color: orange; text-decoration: none;">[ View History ]</a>
            </div>
        </div>

        <div class="col-right">
            <form asp-controller="User" asp-action="UpdateProfile" method="post">
                <input type="hidden" name="id" value="@Model.Id" />
                <input type="hidden" name="Avatar" id="avatarInput" value="@pic" />
                <div class="box">
                    <h2>Profile</h2>

                    <label>Display Name</label>
                    <input type="text" name="Name" value="@Name" @(isOwnProfile ? "" : "readonly") />

                    <label>Bio</label>
                    <textarea name="Bio" rows="3" @(isOwnProfile ? "" : "readonly")>@bio</textarea>

                    <label>Games</label>
                    <textarea name="GameLibraryString" rows="2">@gameLibraryDisplay</textarea>

                    <label>Vibe</label>
                    <div id="vibeContainer" style="@(isOwnProfile ? "" : "pointer-events: none;")">
                        <input type="hidden" name="VibeTagsString" id="VibeTagsString"
                               value="@string.Join(",", Model.VibeTags)" />

                        <button type="button" class="btn @(Model.VibeTags.Contains("Chill") ? "active" : "")"
                                onclick="toggleVibe(this, 'Chill')">Chill</button>
                        <button type="button" class="btn @(Model.VibeTags.Contains("Tryhard") ? "active" : "")"
                                onclick="toggleVibe(this, 'Tryhard')">Tryhard</button>
                        <button type="button" class="btn @(Model.VibeTags.Contains("Teacher") ? "active" : "")"
                                onclick="toggleVibe(this, 'Teacher')">Teacher</button>
                        <button type="button" class="btn @(Model.VibeTags.Contains("Party") ? "active" : "")"
                                onclick="toggleVibe(this, 'Party')">Party</button>
                    </div>
                </div>

                <div class="box">
                    <h2>Social Links</h2>

                    <label>Discord</label>
                    <div class="input-group">
                        <span class="material-symbols-outlined">chat_bubble</span>
                        <input type="text" name="discord" value="@discord" @(isOwnProfile ? "" : "readonly") />
                    </div>

                    <label>Steam</label>
                    <div class="input-group">
                        <span class="material-symbols-outlined">sports_esports</span>
                        <input type="text" name="steam" value="@steam" @(isOwnProfile ? "" : "readonly") />
                    </div>

                    <label>Twitch</label>
                    <div class="input-group">
                        <span class="material-symbols-outlined">live_tv</span>
                        <input type="text" name="twitch" value="@twitch" @(isOwnProfile ? "" : "readonly") />
                    </div>
                </div>

                @if (isOwnProfile)
                {
                    <div style="text-align: right;">
                        <button type="submit" class="btn-save">SAVE DATA</button>
                    </div>
                }
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
                function toggleVibe(btn, vibeName) {
                    btn.classList.toggle('active');

                    const activeButtons = document.querySelectorAll('#vibeContainer .btn.active');

                    const selectedVibes = Array.from(activeButtons).map(b => b.innerText.trim());

                    document.getElementById('VibeTagsString').value = selectedVibes.join(',');
                }

                function changeAvatar() {
                    var img = document.getElementById('profileImage');

                    var currentPic = img.src;
                    var newUrl = prompt("ใส่ URL รูปภาพใหม่ของคุณที่นี่:");

                    if (newUrl !== null && newUrl.trim() !== "") {
                        img.src = newUrl.trim();

                        var avatarInput = document.getElementById('avatarInput');
                        if (avatarInput) {
                            avatarInput.value = newUrl.trim();
                        }
                    }
                }
    </script>
}