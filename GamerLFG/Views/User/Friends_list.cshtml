@model List<GamerLFG.Models.User>
@{
    ViewData["Title"] = "Friends List";
}

<link rel="stylesheet" href="~/css/friends_list.css" asp-append-version="true" />

<h1>Friends List</h1>


<ul class="nav-tabs">
    <li id="friends" class="rbx-tab active"><a asp-controller="User" asp-action="Friends_list">
        <span class="text-lead">Friends</span></a>
    </li>
    <li id="requests" class="rbx-tab"><a asp-controller="User" asp-action="Friends_request"><span
        class="text-lead">Requests</span></a>
    </li>
</ul>

<div class="friends-filter">
    <div class="friends-filter-searchbar-container">
        <span class="icon-search"></span>
        <input id="searchInput" class="friends-filter-searchbar-input" type="text" placeholder="Search Users">
    </div>
</div>

<div id="searchResultsContainer" class="friend-card-containers">
    <ul id="searchResultList" class="friend-cards">
    </ul>
</div>


<div id="friend_containers" class="friend-card-containers">
    <ul class="friend-cards">

        @if (Model != null && Model.Count > 0)
        {
            @foreach (var friend in Model)
            {
                <li id="@friend.Id" onclick="openUserMiniProfile('@friend.Id')" class="list-item friend-card">
                    <div class="friend-card-container">
                        <div class="friend-card-content">
                            <div class="friend-card-fullbody">
                                <a href="/users/@friend.Id/profile" class="friend-card-link">
                                    <span class="friend-card-image">
                                        <img src="@friend.Avatar" alt="@friend.Username" title="@friend.Username">
                                    </span>
                                </a>
                                <div class="avatar-status"></div>
                            </div>

                            <div class="friend-card-caption">
                                <span>
                                    <div class="avatar-name-container">
                                        <a href="/users/@friend.Id/profile" class="text-overflow avatar-name">
                                            @friend.Username
                                        </a>
                                    </div>
                                    <div class="friend-card-label"> @friend.Username </div>
                                    <div class="friend-card-label">
                                        @(friend.VibeTags.Any() ? friend.VibeTags.First() : "Offline")
                                    </div>
                                </span>
                            </div>
                        </div>
                    </div>
                </li>
            }
        }
        else
        {
            <p>ยังไม่มีเพื่อนในรายชื่อ</p>
        }

    </ul>
</div>

<script>
    // จับเหตุการณ์ตอนผู้ใช้พิมพ์ข้อความในช่อง Search
    document.getElementById('searchInput').addEventListener('input', function (e) {
        let keyword = e.target.value;

        // ถ้าลบข้อความจนหมด ให้ล้างหน้าจอผลลัพธ์
        if (keyword.trim() === '') {
            document.getElementById('searchResultList').innerHTML = '';
            document.getElementById('friend_containers').style.display = "block"
            return;
        }

        // ยิง Fetch API ไปหา Controller ของเรา
        fetch(`/User/SearchAPI?keyword=${encodeURIComponent(keyword)}`)
            .then(response => response.json())
            .then(users => {
                let resultHtml = '';

                if (users.length === 0) {
                    resultHtml = '<li><p>ไม่พบผู้ใช้ที่ค้นหา</p></li>';
                } else {
                    document.getElementById('friend_containers').style.display = "None"
                    users.forEach(user => {
                        resultHtml += `
                        <li id="${user.id}" onclick="openUserMiniProfile('${user.id}')" class="list-item friend-card">
                            <div class="friend-card-container">
                                <div class="friend-card-content">
                                    <div class="friend-card-fullbody">
                                        <a href="/users/${user.id}/profile" class="friend-card-link">
                                            <span class="friend-card-image">
                                                <img src="${user.avatar || 'https://via.placeholder.com/150'}" alt="${user.username}">
                                            </span>
                                        </a>
                                    </div>
                                    <div class="friend-card-caption">
                                        <span>
                                            <div class="avatar-name-container">
                                                <a href="/users/${user.id}/profile" class="text-overflow avatar-name">${user.username}</a>
                                            </div>
                                            <div class="friend-card-label">${user.bio || 'ไม่มีข้อมูลแนะนำตัว'}</div>
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </li>`;
                    });
                }

                // เอา HTML ที่สร้างเสร็จแล้วไปยัดใส่หน้าจอ
                document.getElementById('searchResultList').innerHTML = resultHtml;
            })
            .catch(error => console.error('Error searching users:', error));
    });
</script>