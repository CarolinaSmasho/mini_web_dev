@{
    ViewData["Title"] = "Login - Gamer Hub";
}

<link rel="stylesheet" href="~/css/login.css" />

<div class="login-container">
    <div class = "login-box">
        <h1 style="color:white">
            Login
        </h1>
        @if (!ViewData.ModelState.IsValid)
    {
        <div style="color: #ff6b6b; font-size: 14px; margin-bottom: 15px; text-align: center;">
            <div asp-validation-summary="ModelOnly" style="list-style: none; padding: 0;"></div>
        </div>
    }
       <form asp-action="Login" method="post">
            <div class="form-group">
                <input type="text" name = "username" placeholder="Username" required />
            </div>

            <div class="form-group">
                <input type="password" name = "password" placeholder="Password" required />
            </div>

            <button type="submit" class="login-button" style="width: 100%; border-radius: 50px; padding: 12px;">Login</button>
        </form>

        <p style="color: white; margin: 25px;font-size:14px">
            Don't have an account? <a asp-controller="Auth" asp-action="Register" style="color: white; font-weight: bold; text-decoration: none;">Register</a>
        </p>
    </div>

</div>